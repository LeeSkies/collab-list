{
  "name": "shared-grocery-list",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:start": "npx supabase@2.109.1 start",
    "db:stop": "npx supabase@2.109.1 stop",
    "db:reset": "npx supabase@2.109.1 db reset",
    "db:test": "npx supabase@2.109.1 test db",
    "db:lint": "npx supabase@2.109.1 db lint --local",
    "types:supabase": "npx supabase@2.109.1 gen types typescript --local > src/lib/database.types.ts",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.109.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.161.3",
    "@tanstack/router-plugin": "^1.161.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "i18next": "^26.3.6",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.5",
    "supabase": "^2.109.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}

# Browser-safe Supabase values. Use the local values printed by `npm run db:start`
# or the publishable values from your hosted project.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key

# CLI-only credential. Keep this in .env.local; never commit it.
SUPABASE_ACCESS_TOKEN=replace-with-personal-access-token
